# Public browser integrations
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_CLARITY_PROJECT_ID=""

# Server-side GA4 Purchase dispatch
GA4_API_SECRET="replace-with-ga4-measurement-protocol-secret"

# Wiapy webhook authentication
WIAPY_WEBHOOK_SECRET="replace-with-wiapy-webhook-secret"

# Internal funnel dashboard
FUNNEL_DASHBOARD_TOKEN="replace-with-dashboard-token"

# Supabase service credentials
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-with-service-role-key"

# Optional Redis/Upstash integrations
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Local development escape hatch
DISABLE_HMR="0"
